# Copy this file to .env and fill in your values before running locally
# On a server (Hostinger/Render), set these as environment variables in the dashboard

# Required in production — generate a long random string (e.g. openssl rand -hex 32)
DARAS_SECRET=change-this-to-a-long-random-string

# Admin login credentials
ADMIN_USER=daras_admin
ADMIN_PASS=change-this-to-a-strong-password

# Set to "production" on the server, "development" locally
FLASK_ENV=development

# Set to "1" to enable debug mode locally, always "0" on server
FLASK_DEBUG=1

# Port the app runs on
PORT=5001

# Restrict API access to your domain in production (comma-separated)
# Example: ALLOWED_ORIGINS=https://yourdomain.com
# Leave as * for local development
ALLOWED_ORIGINS=*

# ── AI / RAG Configuration ──────────────────────────────────────────────────
# Get a free API key from: https://aistudio.google.com/apikey
# Without this key the app still works — AI features are simply disabled.
GEMINI_API_KEY=
